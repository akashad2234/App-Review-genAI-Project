{
  "phase": 1,
  "name": "Review Ingestion Pipeline",
  "description": "Imported Groww Play Store reviews, scrubbed PII, and persisted clean data.",
  "llm_provider": "Groq",
  "modules": {
    "config": {
      "path": "src/config.py",
      "groq": {
        "model": "llama-3.3-70b-versatile",
        "max_tokens": 2048,
        "temperature": 0.2
      },
      "reviews": {
        "app_id": "com.groww.v2",
        "review_window_weeks": 8,
        "max_reviews": 200
      }
    },
    "llm_client": {
      "path": "src/llm/groq_client.py",
      "features": [
        "chat_completion wrapper",
        "config driven defaults",
        "retry with exponential backoff",
        "structured result with content and raw response"
      ]
    },
    "pii_scrubber": {
      "path": "src/utils/pii_scrubber.py",
      "removes": [
        "email addresses",
        "phone numbers (Indian and generic international)",
        "Aadhaar like 12 digit IDs"
      ],
      "replacements": {
        "email": "[email removed]",
        "phone": "[phone removed]",
        "id": "[id removed]"
      }
    }
  },
  "tests": {
    "pii_scrubber": "tests/test_pii_scrubber.py",
    "groq_client": "tests/test_groq_client.py"
  },
